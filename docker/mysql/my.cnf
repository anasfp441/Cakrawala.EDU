[mysqld]
# Basic Settings
user = mysql
pid-file = /var/run/mysqld/mysqld.pid
socket = /var/run/mysqld/mysqld.sock
port = 3306
basedir = /usr
datadir = /var/lib/mysql
tmpdir = /tmp
lc-messages-dir = /usr/share/mysql

# Character Set
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci
init-connect = 'SET NAMES utf8mb4'

# Connection Settings
max_connections = 200
max_connect_errors = 100000
max_allowed_packet = 64M
table_open_cache = 4000
table_definition_cache = 2000
open_files_limit = 65535

# Buffer Settings
innodb_buffer_pool_size = 256M
innodb_log_file_size = 64M
innodb_log_buffer_size = 16M
innodb_flush_log_at_trx_commit = 2
innodb_lock_wait_timeout = 50
innodb_flush_method = O_DIRECT

# Query Cache
query_cache_type = 1
query_cache_size = 32M
query_cache_limit = 2M

# MyISAM Settings
key_buffer_size = 32M
myisam_sort_buffer_size = 8M
myisam_max_sort_file_size = 10G
myisam_repair_threads = 1

# Logging
log_error = /var/log/mysql/error.log
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 2
log_queries_not_using_indexes = 1

# Binary Logging
log_bin = /var/log/mysql/mysql-bin.log
binlog_format = ROW
expire_logs_days = 7
max_binlog_size = 100M
sync_binlog = 1

# Replication
server_id = 1
read_only = 0
binlog_do_db = cbt_sekolah_db
binlog_ignore_db = mysql,information_schema,performance_schema,sys

# Security
local_infile = 0
skip_symbolic_links = 1
secure_file_priv = /var/lib/mysql-files

# Performance
tmp_table_size = 64M
max_heap_table_size = 64M
sort_buffer_size = 4M
read_buffer_size = 2M
read_rnd_buffer_size = 8M
join_buffer_size = 4M
thread_cache_size = 8

# InnoDB Settings
innodb_file_per_table = 1
innodb_data_file_path = ibdata1:10M:autoextend
innodb_autoextend_increment = 64
innodb_buffer_pool_instances = 1
innodb_read_io_threads = 4
innodb_write_io_threads = 4
innodb_io_capacity = 200
innodb_io_capacity_max = 400
innodb_lru_scan_depth = 1024
innodb_thread_concurrency = 0
innodb_adaptive_hash_index = 1
innodb_change_buffering = all
innodb_old_blocks_pid = 3
innodb_old_blocks_time = 1000

# SQL Mode
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION

# Time Zone
default-time-zone = '+07:00'

# Event Scheduler
event_scheduler = ON

# GTID
gtid_mode = ON
enforce_gtid_consistency = ON

# Group Replication (if needed)
# group_replication_group_name = "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
# group_replication_start_on_boot = OFF
# group_replication_local_address = "192.168.1.10:33061"
# group_replication_group_seeds = "192.168.1.10:33061,192.168.1.11:33061,192.168.1.12:33061"

[mysql]
default-character-set = utf8mb4
auto-rehash = 1
prompt = "CBT_Sekolah_DB [\d]> "

[mysqladmin]
default-character-set = utf8mb4

[mysqldump]
default-character-set = utf8mb4
single-transaction = 1
routines = 1
triggers = 1
hex-blob = 1
add-drop-database = 1
add-drop-table = 1
add-locks = 1
extended-insert = 1
quick = 1
max_allowed_packet = 64M

[client]
default-character-set = utf8mb4
port = 3306
socket = /var/run/mysqld/mysqld.sock

[mysqlimport]
default-character-set = utf8mb4

[mysqlcheck]
default-character-set = utf8mb4