# CBT Sekolah - Environment Configuration
# Copy this file to .env and modify the values according to your environment

# Application Configuration
APP_NAME="CBT Sekolah"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_KEY=base64:your-32-character-base64-encoded-key-here

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cbt_sekolah_db
DB_USERNAME=cbt_web
DB_PASSWORD=cbt_web_password_2024
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Redis Configuration
REDIS_HOST=localhost
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@cbtsekolah.com
MAIL_PASSWORD=your-smtp-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@cbtsekolah.com
MAIL_FROM_NAME="${APP_NAME}"

# File Upload Configuration
UPLOAD_MAX_FILESIZE=10M
POST_MAX_SIZE=12M
ALLOWED_FILE_TYPES=pdf,doc,docx,ppt,pptx,jpg,jpeg,png,gif
UPLOAD_PATH=uploads/
MATERI_PATH=uploads/materi/
TUGAS_PATH=uploads/tugas/

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIES=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# Cache Configuration
CACHE_DRIVER=file
CACHE_PREFIX=cbt_
CACHE_TTL=3600

# Security Configuration
BCRYPT_ROUNDS=12
JWT_SECRET=your-jwt-secret-key-here
JWT_TTL=60
JWT_REFRESH_TTL=20160

# Exam Configuration
DEFAULT_EXAM_DURATION=90
DEFAULT_QUESTIONS_COUNT=50
DEFAULT_MAX_SCORE=100
DEFAULT_KKM=75.0

# Logging Configuration
LOG_CHANNEL=stack
LOG_LEVEL=error
LOG_DAYS=14

# Queue Configuration
QUEUE_CONNECTION=sync
QUEUE_DRIVER=sync

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_PATH=backups/
BACKUP_RETENTION_DAYS=30
BACKUP_TIME=02:00

# Monitoring Configuration
MONITORING_ENABLED=false
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0

# Development Configuration
DEVELOPER_MODE=false
SHOW_DEBUG_BAR=false
ENABLE_PROFILER=false

# Third Party Services
GOOGLE_ANALYTICS_ID=
FACEBOOK_PIXEL_ID=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# API Configuration
API_RATE_LIMIT=60
API_RATE_LIMIT_WINDOW=1

# SMS Configuration (if using SMS gateway)
SMS_DRIVER=log
SMS_FROM=+6281234567890
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret

# Payment Gateway (if implementing payment features)
PAYMENT_DRIVER=log
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_MERCHANT_ID=your-midtrans-merchant-id

# Social Login (if implementing social authentication)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# File Storage (if using cloud storage)
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Database Backup
DB_BACKUP_ENABLED=true
DB_BACKUP_SCHEDULE=0 2 * * *
DB_BACKUP_RETENTION=30

# Email Templates
EMAIL_TEMPLATE_PATH=resources/email-templates/
EMAIL_SEND_QUEUE=false

# Notification Configuration
PUSH_NOTIFICATIONS_ENABLED=false
FIREBASE_SERVER_KEY=
FIREBASE_PROJECT_ID=

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_ALLOWED_IPS=127.0.0.1,::1

# Performance Configuration
OPCACHE_ENABLED=true
OPCACHE_MEMORY_CONSUMPTION=128
OPCACHE_MAX_ACCELERATED_FILES=4000
OPCACHE_REVALIDATE_FREQ=2

# Security Headers
SECURITY_HEADERS_ENABLED=true
CSP_ENABLED=true
HSTS_ENABLED=false
HSTS_MAX_AGE=31536000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ATTEMPTS=5
RATE_LIMIT_DECAY_MINUTES=1

# File Validation
FILE_VALIDATION_ENABLED=true
FILE_SCAN_ENABLED=false
VIRUS_SCAN_ENABLED=false

# Backup Storage
BACKUP_STORAGE_DRIVER=local
BACKUP_STORAGE_PATH=backups/
BACKUP_COMPRESSION=true
BACKUP_ENCRYPTION=false

# Cron Jobs
CRON_ENABLED=true
CRON_SCHEDULE=* * * * *

# Error Reporting
ERROR_REPORTING_ENABLED=true
ERROR_REPORTING_EMAIL=admin@cbtsekolah.com
ERROR_REPORTING_LEVEL=E_ALL

# Debug Configuration
DEBUG_MODE=false
DEBUG_LEVEL=0
DEBUG_SHOW_TRACE=false

# Testing Configuration
TESTING_ENABLED=false
TEST_DATABASE=cbt_sekolah_test
TEST_MAIL_DRIVER=log

# Production Overrides
if [ "$APP_ENV" = "production" ]; then
    APP_DEBUG=false
    LOG_LEVEL=error
    CACHE_DRIVER=redis
    SESSION_DRIVER=redis
    QUEUE_DRIVER=redis
    MAIL_MAILER=smtp
    FILESYSTEM_DISK=s3
    SECURITY_HEADERS_ENABLED=true
    CSP_ENABLED=true
    HSTS_ENABLED=true
    RATE_LIMIT_ENABLED=true
    FILE_VALIDATION_ENABLED=true
    BACKUP_ENABLED=true
    MONITORING_ENABLED=true
fi

# Development Overrides
if [ "$APP_ENV" = "development" ]; then
    APP_DEBUG=true
    LOG_LEVEL=debug
    CACHE_DRIVER=file
    SESSION_DRIVER=file
    QUEUE_DRIVER=sync
    MAIL_MAILER=log
    FILESYSTEM_DISK=local
    SECURITY_HEADERS_ENABLED=false
    CSP_ENABLED=false
    HSTS_ENABLED=false
    RATE_LIMIT_ENABLED=false
    FILE_VALIDATION_ENABLED=false
    BACKUP_ENABLED=false
    MONITORING_ENABLED=false
fi