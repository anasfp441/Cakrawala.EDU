# CBT Sekolah - Apache Configuration
# File ini berisi konfigurasi web server untuk aplikasi CBT Sekolah

# Enable URL rewriting
RewriteEngine On

# Security Headers
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "DENY"
    
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # Enable XSS protection
    Header always set X-XSS-Protection "1; mode=block"
    
    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self';"
    
    # Remove server information
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# Security Settings
<IfModule mod_rewrite.c>
    # Block access to sensitive files
    RewriteRule ^(config\.php|database\.sql|\.htaccess|README\.md|LICENSE)$ - [F,L]
    
    # Block access to backup files
    RewriteRule \.(bak|backup|old|tmp|temp|log)$ - [F,L]
    
    # Block access to hidden files
    RewriteRule ^\. - [F,L]
</IfModule>

# File Access Control
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

<Files "database.sql">
    Order Allow,Deny
    Deny from all
</Files>

<Files ".htaccess">
    Order Allow,Deny
    Deny from all
</Files>

<Files "README.md">
    Order Allow,Deny
    Deny from all
</Files>

# Directory Browsing
Options -Indexes

# Error Pages
ErrorDocument 403 /error/403.html
ErrorDocument 404 /error/404.html
ErrorDocument 500 /error/500.html

# Compression
<IfModule mod_deflate.c>
    # Enable compression for text files
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    
    # Remove browser bugs
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
    Header append Vary User-Agent
</IfModule>

# Caching
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    
    # CSS and JavaScript
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    
    # Fonts
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    
    # HTML
    ExpiresByType text/html "access plus 1 hour"
    
    # PDF
    ExpiresByType application/pdf "access plus 1 month"
    
    # Default
    ExpiresDefault "access plus 1 month"
</IfModule>

# URL Rewriting Rules
<IfModule mod_rewrite.c>
    # Remove trailing slashes
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [R=301,L]
    
    # Handle API requests
    RewriteRule ^api/(.*)$ api/index.php?path=$1 [QSA,L]
    
    # Handle file downloads
    RewriteRule ^download/(.*)$ download.php?file=$1 [QSA,L]
    
    # Handle user profile
    RewriteRule ^profile/([^/]+)/?$ profile.php?username=$1 [QSA,L]
    
    # Handle exam URLs
    RewriteRule ^exam/([0-9]+)/?$ exam.php?id=$1 [QSA,L]
    
    # Handle material URLs
    RewriteRule ^material/([0-9]+)/?$ material.php?id=$1 [QSA,L]
    
    # Handle assignment URLs
    RewriteRule ^assignment/([0-9]+)/?$ assignment.php?id=$1 [QSA,L]
</IfModule>

# PHP Settings
<IfModule mod_php7.c>
    # Security settings
    php_flag display_errors Off
    php_flag log_errors On
    php_flag allow_url_fopen Off
    php_flag allow_url_include Off
    php_flag expose_php Off
    
    # Upload settings
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value max_execution_time 300
    php_value max_input_time 300
    php_value memory_limit 256M
    
    # Session settings
    php_value session.cookie_httponly 1
    php_value session.cookie_secure 0
    php_value session.use_strict_mode 1
    php_value session.cookie_samesite "Strict"
</IfModule>

<IfModule mod_php8.c>
    # Security settings
    php_flag display_errors Off
    php_flag log_errors On
    php_flag allow_url_fopen Off
    php_flag allow_url_include Off
    php_flag expose_php Off
    
    # Upload settings
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value max_execution_time 300
    php_value max_input_time 300
    php_value memory_limit 256M
    
    # Session settings
    php_value session.cookie_httponly 1
    php_value session.cookie_secure 0
    php_value session.use_strict_mode 1
    php_value session.cookie_samesite "Strict"
</IfModule>

# Block Bad Bots
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_USER_AGENT} ^$ [OR]
    RewriteCond %{HTTP_USER_AGENT} ^(java|curl|wget) [NC,OR]
    RewriteCond %{HTTP_USER_AGENT} ^.*(libwww-perl|curl|wget|python|nikto|wkito|pikto|acunetix).* [NC,OR]
    RewriteCond %{HTTP_USER_AGENT} ^.*(winhttp|HTTrack|clshttp|archiver|loader|email|harvest|extract|grab|miner).* [NC]
    RewriteRule .* - [F,L]
</IfModule>

# Block access to sensitive directories
<IfModule mod_rewrite.c>
    RewriteRule ^(logs|backups|cache|temp|tmp)/ - [F,L]
</IfModule>

# Prevent access to .env files
<Files ".env*">
    Order Allow,Deny
    Deny from all
</Files>

# Prevent access to composer files
<Files "composer.*">
    Order Allow,Deny
    Deny from all
</Files>

# Prevent access to package files
<Files "package.*">
    Order Allow,Deny
    Deny from all
</Files>

# Custom error pages
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^error/([0-9]{3})\.html$ error.php?code=$1 [QSA,L]
</IfModule>

# Maintenance mode (uncomment when needed)
# RewriteCond %{REMOTE_ADDR} !^127\.0\.0\.1$
# RewriteCond %{REMOTE_ADDR} !^::1$
# RewriteRule .* /maintenance.html [R=302,L]

# Performance optimization
<IfModule mod_headers.c>
    # Enable keep-alive
    Header set Connection keep-alive
    
    # Cache control for static assets
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000"
    </FilesMatch>
    
    # Cache control for HTML
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>
    
    # Cache control for API responses
    <FilesMatch "\.(json|xml)$">
        Header set Cache-Control "public, max-age=300"
    </FilesMatch>
</IfModule>

# Rate limiting (if mod_ratelimit is available)
<IfModule mod_ratelimit.c>
    # Limit requests per IP
    SetOutputFilter RATE_LIMIT
    SetEnv rate-limit 400
</IfModule>

# Block suspicious requests
<IfModule mod_rewrite.c>
    # Block SQL injection attempts
    RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} proc/self/environ [OR]
    RewriteCond %{QUERY_STRING} mosConfig [OR]
    RewriteCond %{QUERY_STRING} base64_(en|de)code[^(]*\([^)]*\) [OR]
    RewriteCond %{QUERY_STRING} (<|%3C)([^s]*s)+cript.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} (\<|%3C).*iframe.*(\>|%3E) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# Enable CORS for API (if needed)
<IfModule mod_headers.c>
    <FilesMatch "^api/">
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Header set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
    </FilesMatch>
</IfModule>

# Handle OPTIONS method for CORS
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=200,L]
</IfModule>

# Logging (if mod_log_config is available)
<IfModule mod_log_config.c>
    LogFormat "%h %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-Agent}i\"" combined
    LogFormat "%h %l %u %t \"%r\" %>s %b" common
    
    # Custom log for CBT application
    LogFormat "%h %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-Agent}i\" %D" cbt_log
    
    # Use custom log format
    CustomLog "logs/cbt_access.log" cbt_log
</IfModule>

# Prevent access to log files
<FilesMatch "\.(log|txt)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Allow access to specific log files for admin
<Files "cbt_access.log">
    Order Allow,Deny
    Allow from 127.0.0.1
    Allow from ::1
    # Add your admin IP here
    # Allow from 192.168.1.100
</Files>

# Enable HTTP/2 (if available)
<IfModule mod_http2.c>
    Protocols h2 http/1.1
</IfModule>

# Enable Brotli compression (if available)
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json application/xml+rss
</IfModule>

# Security: Prevent access to version control files
<FilesMatch "\.(git|svn|hg|bzr|cvs)">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Security: Block access to configuration files
<FilesMatch "\.(ini|conf|config|cfg)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Security: Block access to backup files
<FilesMatch "\.(bak|backup|old|orig|save|swp|tmp|temp)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Security: Block access to development files
<FilesMatch "\.(dev|development|test|testing|staging)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Performance: Enable browser caching for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    
    # CSS and JS files
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    
    # Image files
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    
    # Font files
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    
    # Document files
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType application/msword "access plus 1 month"
    ExpiresByType application/vnd.openxmlformats-officedocument.wordprocessingml.document "access plus 1 month"
</IfModule>

# Security: Block access to PHP files in uploads directory
<Directory "uploads">
    <FilesMatch "\.php$">
        Order Allow,Deny
        Deny from all
    </FilesMatch>
    
    # Allow only specific file types
    <FilesMatch "\.(pdf|doc|docx|ppt|pptx|jpg|jpeg|png|gif)$">
        Order Allow,Deny
        Allow from all
    </FilesMatch>
</Directory>

# Security: Block access to PHP files in assets directory
<Directory "assets">
    <FilesMatch "\.php$">
        Order Allow,Deny
        Deny from all
    </FilesMatch>
</Directory>

# Performance: Enable gzip compression for all text files
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml+rss
</IfModule>

# Security: Block access to system files
<FilesMatch "^(\.htaccess|\.htpasswd|\.git|\.svn|\.DS_Store|Thumbs\.db)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Security: Block access to configuration files
<FilesMatch "^(config|database|\.env|\.config|\.conf|\.ini|\.cfg)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Performance: Set default character set
AddDefaultCharset UTF-8

# Security: Disable server signature
ServerSignature Off

# Security: Disable directory browsing
Options -Indexes

# Security: Follow symlinks
Options +FollowSymLinks

# Performance: Enable keep-alive
<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>

# Security: Block access to sensitive HTTP methods
<LimitExcept GET POST>
    Deny from all
</LimitExcept>

# Performance: Enable browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
</IfModule>

# Security: Block access to hidden files
<Files ".*">
    Order Allow,Deny
    Deny from all
</Files>

# Allow access to visible files
<FilesMatch "^[^.]">
    Order Allow,Deny
    Allow from all
</FilesMatch>