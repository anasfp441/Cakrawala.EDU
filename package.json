{
  "name": "cbt-sekolah",
  "version": "1.0.0",
  "description": "Aplikasi CBT (Computer Based Test) Sekolah - Sistem Pembelajaran Berbasis Komputer",
  "main": "index.html",
  "scripts": {
    "start": "php -S localhost:8000",
    "dev": "php -S localhost:8000",
    "build": "npm run build:css && npm run build:js",
    "build:css": "postcss styles.css -o dist/styles.min.css",
    "build:js": "terser script.js -o dist/script.min.js",
    "lint:css": "stylelint styles.css",
    "lint:js": "eslint script.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "format": "prettier --write \"**/*.{js,css,html,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,css,html,json,md}\"",
    "lint": "npm run lint:css && npm run lint:js",
    "prepare": "husky install",
    "postinstall": "npm run build",
    "clean": "rm -rf dist/ node_modules/",
    "docs": "jsdoc -c jsdoc.json",
    "serve": "live-server --port=3000 --open=/",
    "analyze": "webpack-bundle-analyzer dist/stats.json",
    "security": "npm audit",
    "security:fix": "npm audit fix",
    "update": "npm update",
    "outdated": "npm outdated",
    "version": "npm version patch && git push && git push --tags",
    "deploy": "npm run build && rsync -avz dist/ user@server:/var/www/html/cbt-sekolah/",
    "backup": "mysqldump -u root -p cbt_sekolah_db > backup_$(date +%Y%m%d_%H%M%S).sql",
    "restore": "mysql -u root -p cbt_sekolah_db < backup_*.sql",
    "docker:build": "docker build -t cbt-sekolah .",
    "docker:run": "docker run -p 8080:80 cbt-sekolah",
    "docker:stop": "docker stop $(docker ps -q --filter ancestor=cbt-sekolah)",
    "docker:clean": "docker system prune -f"
  },
  "keywords": [
    "cbt",
    "sekolah",
    "pendidikan",
    "ujian-online",
    "sistem-pembelajaran",
    "computer-based-test",
    "education",
    "learning-management-system",
    "lms",
    "indonesia"
  ],
  "author": {
    "name": "CBT Sekolah Team",
    "email": "team@cbtsekolah.com",
    "url": "https://cbtsekolah.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/username/cbt-sekolah.git"
  },
  "bugs": {
    "url": "https://github.com/username/cbt-sekolah/issues"
  },
  "homepage": "https://cbtsekolah.com",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "autoprefixer": "^10.4.14",
    "babel-loader": "^9.1.0",
    "clean-css-cli": "^5.6.0",
    "css-loader": "^6.8.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.27.0",
    "eslint-plugin-jsx-a11y": "^6.7.0",
    "eslint-plugin-prettier": "^4.2.0",
    "eslint-plugin-react": "^7.32.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "jsdoc": "^4.0.0",
    "lint-staged": "^13.2.0",
    "live-server": "^1.2.2",
    "postcss": "^8.4.24",
    "postcss-cli": "^10.1.0",
    "postcss-loader": "^7.3.0",
    "prettier": "^2.8.8",
    "style-loader": "^3.3.0",
    "stylelint": "^15.6.0",
    "stylelint-config-prettier": "^9.0.0",
    "stylelint-config-standard": "^30.0.0",
    "stylelint-order": "^6.0.0",
    "terser": "^5.17.0",
    "uglify-js": "^3.17.4",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  },
  "dependencies": {
    "chart.js": "^4.3.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^2.30.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "sweetalert2": "^11.7.0",
    "toastr": "^2.1.4",
    "validator": "^13.9.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "optionalDependencies": {
    "fsevents": "*"
  },
  "bundledDependencies": [
    "chart.js",
    "lodash"
  ],
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,less}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{html,json,md}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "moduleNameMapping": {
      "\\.(css|less|scss|sass)$": "identity-obj-proxy",
      "\\.(gif|ttf|eot|svg)$": "<rootDir>/tests/__mocks__/fileMock.js"
    },
    "collectCoverageFrom": [
      "script.js",
      "!**/node_modules/**",
      "!**/coverage/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "babel": {
    "presets": [
      "@babel/preset-env",
      "@babel/preset-react"
    ]
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {},
      "cssnano": {
        "preset": "default"
      }
    }
  },
  "stylelint": {
    "extends": [
      "stylelint-config-standard",
      "stylelint-config-prettier"
    ],
    "plugins": [
      "stylelint-order"
    ],
    "rules": {
      "order/properties-order": [
        "position",
        "top",
        "right",
        "bottom",
        "left",
        "z-index",
        "display",
        "float",
        "width",
        "height",
        "max-width",
        "max-height",
        "min-width",
        "min-height",
        "padding",
        "padding-top",
        "padding-right",
        "padding-bottom",
        "padding-left",
        "margin",
        "margin-top",
        "margin-right",
        "margin-bottom",
        "margin-left",
        "border",
        "border-width",
        "border-style",
        "border-color",
        "border-top",
        "border-top-width",
        "border-top-style",
        "border-top-color",
        "border-right",
        "border-right-width",
        "border-right-style",
        "border-right-color",
        "border-bottom",
        "border-bottom-width",
        "border-bottom-style",
        "border-bottom-color",
        "border-left",
        "border-left-width",
        "border-left-style",
        "border-left-color",
        "border-radius",
        "border-top-left-radius",
        "border-top-right-radius",
        "border-bottom-right-radius",
        "border-bottom-left-radius",
        "background",
        "background-color",
        "background-image",
        "background-repeat",
        "background-attachment",
        "background-position",
        "background-size",
        "color",
        "font",
        "font-family",
        "font-size",
        "font-weight",
        "font-style",
        "font-variant",
        "line-height",
        "text-align",
        "text-decoration",
        "text-indent",
        "text-transform",
        "letter-spacing",
        "word-spacing",
        "white-space",
        "vertical-align",
        "cursor",
        "visibility",
        "opacity",
        "content",
        "quotes",
        "counter-reset",
        "counter-increment",
        "resize",
        "outline",
        "outline-width",
        "outline-style",
        "outline-color",
        "outline-offset",
        "box-shadow",
        "transform",
        "transition",
        "animation"
      ]
    }
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "plugin:import/errors",
      "plugin:import/warnings",
      "plugin:jsx-a11y/recommended",
      "plugin:react/recommended",
      "plugin:react-hooks/recommended",
      "prettier"
    ],
    "plugins": [
      "import",
      "jsx-a11y",
      "react",
      "react-hooks",
      "prettier"
    ],
    "rules": {
      "prettier/prettier": "error",
      "no-console": "warn",
      "no-debugger": "warn",
      "no-unused-vars": "warn",
      "prefer-const": "error",
      "no-var": "error"
    },
    "env": {
      "browser": true,
      "es6": true,
      "node": true,
      "jest": true
    },
    "parserOptions": {
      "ecmaVersion": 2020,
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      }
    },
    "settings": {
      "react": {
        "version": "detect"
      }
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false,
    "bracketSpacing": true,
    "arrowParens": "avoid",
    "endOfLine": "lf"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "workspaces": [
    "packages/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "src/",
    "*.html",
    "*.css",
    "*.js",
    "*.php",
    "*.sql",
    "*.md",
    "LICENSE"
  ],
  "directories": {
    "lib": "dist/",
    "test": "tests/",
    "docs": "docs/"
  },
  "man": [
    "docs/man/cbt-sekolah.1"
  ],
  "bin": {
    "cbt-sekolah": "./bin/cbt-sekolah.js"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/username"
  },
  "contributors": [
    {
      "name": "Developer 1",
      "email": "dev1@cbtsekolah.com"
    },
    {
      "name": "Developer 2",
      "email": "dev2@cbtsekolah.com"
    }
  ],
  "maintainers": [
    {
      "name": "Maintainer",
      "email": "maintainer@cbtsekolah.com"
    }
  ]
}