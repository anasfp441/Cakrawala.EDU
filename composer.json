{
  "name": "cbt-sekolah/cbt-sekolah",
  "description": "Aplikasi CBT (Computer Based Test) Sekolah - Sistem Pembelajaran Berbasis Komputer",
  "type": "project",
  "keywords": [
    "cbt",
    "sekolah",
    "pendidikan",
    "ujian-online",
    "sistem-pembelajaran",
    "computer-based-test",
    "education",
    "learning-management-system",
    "lms",
    "indonesia"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "CBT Sekolah Team",
      "email": "team@cbtsekolah.com",
      "homepage": "https://cbtsekolah.com"
    }
  ],
  "require": {
    "php": "^8.0|^8.1|^8.2",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-curl": "*",
    "ext-gd": "*",
    "ext-zip": "*",
    "ext-openssl": "*",
    "ext-fileinfo": "*",
    "ext-intl": "*",
    "monolog/monolog": "^3.0",
    "phpmailer/phpmailer": "^6.8",
    "vlucas/phpdotenv": "^5.5",
    "firebase/php-jwt": "^6.8",
    "ramsey/uuid": "^4.7",
    "intervention/image": "^2.7",
    "dompdf/dompdf": "^2.0",
    "phpoffice/phpspreadsheet": "^1.29",
    "symfony/http-foundation": "^6.3",
    "symfony/validator": "^6.3",
    "symfony/security-core": "^6.3",
    "doctrine/dbal": "^3.6",
    "doctrine/orm": "^2.16",
    "twig/twig": "^3.7",
    "predis/predis": "^2.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.10",
    "squizlabs/php_codesniffer": "^3.7",
    "friendsofphp/php-cs-fixer": "^3.20",
    "phpdocumentor/phpdocumentor": "^3.4",
    "symfony/var-dumper": "^6.3",
    "filp/whoops": "^2.15",
    "barryvdh/laravel-debugbar": "^3.8"
  },
  "autoload": {
    "psr-4": {
      "CBT\\": "src/",
      "CBT\\Controllers\\": "src/Controllers/",
      "CBT\\Models\\": "src/Models/",
      "CBT\\Services\\": "src/Services/",
      "CBT\\Helpers\\": "src/Helpers/",
      "CBT\\Middleware\\": "src/Middleware/"
    },
    "psr-0": {
      "CBT": "src/"
    },
    "files": [
      "src/Helpers/functions.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "CBT\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-html coverage",
    "cs:check": "php-cs-fixer fix --dry-run --diff",
    "cs:fix": "php-cs-fixer fix",
    "stan": "phpstan analyse src tests",
    "docs": "phpdoc",
    "post-install-cmd": [
      "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-update-cmd": [
      "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "composer",
      "url": "https://packagist.org"
    }
  ]
}